{
  "swagger": "2.0",
  "info": {
    "title": "RouteScout Trips API",
    "description": "Backend service for the RouteScout web app. Stores and retrieves trip data including stops, routes, and preferences.",
    "version": "1.0.0"
  },
  "host": "routescoutbackend.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/trips/": {
      "post": {
        "tags": [
          "Trips"
        ],
        "description": "Create a new trip and return its ID.",
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/trips/{id}/share": {
      "get": {
        "tags": [
          "Trips"
        ],
        "description": "Retrieve a single trip by its MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/trips/{id}": {
      "get": {
        "tags": [
          "Trips"
        ],
        "description": "Retrieve a single trip by its MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "put": {
        "tags": [
          "Trips"
        ],
        "description": "Partially update a trip by its MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "delete": {
        "tags": [
          "Trips"
        ],
        "description": "Delete a trip by its MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  }
}